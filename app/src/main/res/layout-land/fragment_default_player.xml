<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/constraintLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?colorSurface"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@+id/blur"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:foreground="@drawable/radial_gradient"
        android:importantForAccessibility="no"
        android:scaleType="centerCrop"
        android:visibility="gone"
        tools:src="@tools:sample/backgrounds/scenic"/>

    <!-- 辅助参考线：将屏幕划分为左45%和右55% -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/center_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.45" />

    <!-- ================= 左侧区域重构：顶歌名 + 中封面 + 底进度 ================= -->

    <!-- 1. 顶部：歌名 (居中对齐，顶到系统状态栏下方) -->
	<!-- android:layout_marginTop="24dp🎛️ 调试数值A：距离屏幕顶部的极限距离。如果想更靠上可以改成 8dp 或 12dp -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/leftCoverInfoText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp" 
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:singleLine="true"
        android:ellipsize="marquee"
        android:gravity="center"
        android:textSize="18sp"
        android:textColor="?android:attr/textColorPrimary"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"  
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/center_guideline" />

    <!-- 2. 中间：封面容器 (被顶部的歌名和底部的进度条完美夹在中间) -->
    <FrameLayout
        android:id="@+id/coverContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="0dp"
        android:layout_marginBottom="6dp"
        app:layout_constraintDimensionRatio="1:1"  
        app:layout_constraintTop_toBottomOf="@+id/leftCoverInfoText"  
        app:layout_constraintBottom_toTopOf="@+id/inlineProgressSlider"  
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/center_guideline">
        
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/playerAlbumCoverFragment"
            android:name="com.mardous.booming.ui.screen.player.cover.CoverPagerFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            tools:layout="@layout/fragment_album_cover_default"/>
    </FrameLayout>

    <!-- 3. 底部：迷你进度条 (独占一行，极致贴底) -->
	<!--android:layout_marginBottom="24dp" 🎛️ 调试数值C：距离屏幕底部的极限摆放高度。如果要贴底可以改成 8dp -->
	<!-- android:layout_height="24dp"🎛️ 调试数值B：进度条高度（触控区）。建议保留 24dp 保证好拉动 -->
	<!-- constraintBottom_toBottomOf="parent"🔑 牢牢吸附在屏幕最底端 -->
    <androidx.appcompat.widget.AppCompatSeekBar
        android:id="@+id/inlineProgressSlider"
        android:layout_width="0dp"
        android:layout_height="24dp" 
        android:layout_marginBottom="12dp" 
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:background="@null"
        android:stateListAnimator="@null"
        android:focusable="false"
        android:splitTrack="false"
        android:thumb="@null"
        android:minHeight="4dp"
        android:maxHeight="4dp"
        android:progressTint="?android:attr/textColorPrimary"
        app:layout_constraintBottom_toBottomOf="parent" 
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/center_guideline" />

    <!-- ================= 右侧区域 ================= -->

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/playbackControlsFragment"
        android:name="com.mardous.booming.ui.screen.player.styles.defaultstyle.DefaultPlayerControlsFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/toolbar"
        app:layout_constraintStart_toEndOf="@+id/center_guideline"
        app:layout_constraintEnd_toEndOf="parent"
        tools:layout="@layout/fragment_default_player_playback_controls"/>

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?actionBarSize"
        android:theme="@style/ThemeOverlay.MaterialComponents.ActionBar"
        android:elevation="0dp"
        app:navigationIcon="@drawable/ic_volume_up_24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@+id/playbackControlsFragment"
        app:layout_constraintEnd_toEndOf="@+id/playbackControlsFragment"
        tools:menu="@menu/menu_now_playing"/>

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/rightLyricsFragment"
        android:name="com.mardous.booming.ui.screen.player.cover.CoverLyricsFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:elevation="5dp" 
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" 
        app:layout_constraintStart_toEndOf="@+id/center_guideline"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>