<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/constraintLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?colorSurface"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@+id/blur"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:foreground="@drawable/radial_gradient"
        android:importantForAccessibility="no"
        android:scaleType="centerCrop"
        android:visibility="gone"
        tools:src="@tools:sample/backgrounds/scenic"/>

    <!-- ================= 左侧原生封面区域 (已放大) ================= -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/playerAlbumCoverFragment"
        android:name="com.mardous.booming.ui.screen.player.cover.CoverPagerFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:layout="@layout/fragment_album_cover_default"/>

    <!-- 覆盖在封面上的透明玻璃层，截获点击并【智能穿透】滑动事件 -->
    <View
        android:id="@+id/coverClickOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clickable="true"
        android:focusable="true"
        android:elevation="2dp"
        android:background="?selectableItemBackground"
        app:layout_constraintTop_toTopOf="@+id/playerAlbumCoverFragment"
        app:layout_constraintBottom_toBottomOf="@+id/playerAlbumCoverFragment"
        app:layout_constraintStart_toStartOf="@+id/playerAlbumCoverFragment"
        app:layout_constraintEnd_toEndOf="@+id/playerAlbumCoverFragment" />

    <!-- ================= 右侧播放控制区 ================= -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/playbackControlsFragment"
        android:name="com.mardous.booming.ui.screen.player.styles.defaultstyle.DefaultPlayerControlsFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/toolbar"
        app:layout_constraintStart_toEndOf="@+id/playerAlbumCoverFragment"
        app:layout_constraintEnd_toEndOf="parent"
        tools:layout="@layout/fragment_default_player_playback_controls"/>

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?actionBarSize"
        android:theme="@style/ThemeOverlay.MaterialComponents.ActionBar"
        android:elevation="0dp"
        app:navigationIcon="@drawable/ic_volume_up_24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@+id/playbackControlsFragment"
        app:layout_constraintEnd_toEndOf="@+id/playbackControlsFragment"
        tools:menu="@menu/menu_now_playing"/>

    <!-- ================= 右侧全屏歌词区 ================= -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/rightLyricsFragment"
        android:name="com.mardous.booming.ui.screen.player.cover.CoverLyricsFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:elevation="5dp" 
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" 
        app:layout_constraintStart_toEndOf="@+id/playerAlbumCoverFragment"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 【新增】：全局悬浮侧边栏，完美对齐，节省空间 -->
    <LinearLayout
        android:id="@+id/lyricsActionContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:visibility="gone"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp"
        android:elevation="10dp"
        app:layout_constraintBottom_toBottomOf="@+id/rightLyricsFragment"
        app:layout_constraintEnd_toEndOf="@+id/rightLyricsFragment">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/lyricsFavoriteButton"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginBottom="4dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:padding="0dp"
            app:elevation="0dp"
            app:cornerRadius="18dp"
            app:backgroundTint="@android:color/transparent"
            app:rippleColor="?attr/colorControlHighlight"
            app:icon="@drawable/ic_favorite_outline_24dp"
            app:iconSize="22dp" />

        <TextView
            android:id="@+id/lyricsTranslationButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginBottom="4dp"
            android:text="译"
            android:gravity="center"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="?selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/lyricsExpandButton"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:padding="0dp"
            app:elevation="0dp"
            app:cornerRadius="18dp"
            app:backgroundTint="@android:color/transparent"
            app:rippleColor="?attr/colorControlHighlight"
            app:icon="@drawable/ic_open_in_full_24dp"
            app:iconSize="22dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>